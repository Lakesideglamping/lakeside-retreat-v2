# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Admin Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=   # bcrypt hash, generate with: node -e "require('bcryptjs').hash('password',10).then(console.log)"
JWT_SECRET=            # 64-char hex string
CSRF_SECRET=           # 64-char hex string
TOTP_ENCRYPTION_KEY=   # 64-char hex string (for future 2FA)

# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Uplisting PMS
UPLISTING_API_KEY=
UPLISTING_WEBHOOK_SECRET=
UPLISTING_PINOT_ID=
UPLISTING_ROSE_ID=
UPLISTING_COTTAGE_ID=

# Email (Titan SMTP)
EMAIL_HOST=smtp.titan.email
EMAIL_PORT=587
EMAIL_USER=info@lakesideretreat.co.nz
EMAIL_PASS=
CONTACT_EMAIL=info@lakesideretreat.co.nz

# Cron Jobs
CRON_SECRET=           # Bearer token for cron job auth

# Feature flags
MAINTENANCE_MODE=false # Set to "true" to serve a maintenance page site-wide

# iCal feed signing
ICAL_SECRET=           # Shared secret used to sign iCal export URLs

# Password reset
RESET_TOKEN=           # Signing secret for password-reset tokens

# Sentry (optional — omit to disable)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Optional
OPENAI_API_KEY=        # For AI chatbot enhancement
LOG_LEVEL=info         # debug, info, warn, error

# Public
NEXT_PUBLIC_BASE_URL=https://lakesideretreat.co.nz
