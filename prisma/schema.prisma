generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model abandoned_checkout_reminders {
  id                    Int      @id @default(autoincrement())
  booking_id            String   @unique
  guest_email           String
  guest_name            String?
  accommodation         String?
  check_in              String?
  check_out             String?
  reminder_count        Int?     @default(0)
  last_reminder_sent_at String?
  last_error            String?
  created_at            String?  @default(dbgenerated("CURRENT_TIMESTAMP"))

  // Cron query: WHERE reminder_count < 3 AND last_reminder_sent_at < now()-7d
  @@index([reminder_count, last_reminder_sent_at])
}

model audit_logs {
  id         Int       @id @default(autoincrement())
  admin_user String
  action     String
  details    String?
  ip_address String?
  created_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([action], map: "idx_audit_logs_action")
  @@index([created_at], map: "idx_audit_logs_created_at")
}

model bookings {
  id                              String    @id
  guest_name                      String
  guest_email                     String
  guest_phone                     String?
  accommodation                   String
  check_in                        DateTime  @db.Date
  check_out                       DateTime  @db.Date
  guests                          Int
  total_price                     Decimal?  @db.Decimal(10, 2)
  status                          String?   @default("confirmed")
  payment_status                  String?   @default("pending")
  notes                           String?
  stripe_session_id               String?
  stripe_payment_id               String?
  uplisting_id                    String?
  created_at                      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime? @default(now()) @db.Timestamptz(6)
  deposit_release_due             DateTime? @db.Timestamptz(6)
  booking_source                  String?   @default("unknown")
  uplisting_sync_status           String?   @default("pending")
  uplisting_sync_retries          Int?      @default(0)
  security_deposit_intent_id      String?
  security_deposit_status         String?   @default("pending")
  security_deposit_amount         Decimal?  @default(300.00) @db.Decimal(10, 2)
  security_deposit_released_at    DateTime? @db.Timestamp(6)
  security_deposit_claimed_amount Decimal?  @default(0) @db.Decimal(10, 2)
  deleted_at                      DateTime? @db.Timestamp(6)

  @@index([accommodation], map: "idx_bookings_accommodation")
  @@index([booking_source], map: "idx_bookings_booking_source")
  @@index([check_in], map: "idx_bookings_check_in")
  @@index([check_out], map: "idx_bookings_check_out")
  @@index([created_at], map: "idx_bookings_created_at")
  @@index([check_in, check_out], map: "idx_bookings_dates")
  @@index([payment_status], map: "idx_bookings_payment_status")
  @@index([status], map: "idx_bookings_status")
  @@index([stripe_session_id], map: "idx_bookings_stripe_session")
  // Covers release-deposits cron: WHERE security_deposit_status = 'held'
  // AND deposit_release_due <= now(). Without this the cron full-scans.
  @@index([security_deposit_status, deposit_release_due], map: "idx_bookings_deposit_release")
  // Partial index for soft-delete queries — every findMany filters deleted_at IS NULL.
  @@index([deleted_at], map: "idx_bookings_deleted_at", where: raw("deleted_at IS NOT NULL"))
  // Prevent duplicate website bookings for the same accommodation + dates.
  // OTA bookings (airbnb, booking.com, etc.) are exempt. Cancelled bookings
  // (deleted_at IS NOT NULL) are also exempt so guests can rebook after cancellation.
  @@index([accommodation, check_in, check_out], map: "idx_bookings_unique_website_dates", where: raw("booking_source = 'website' AND deleted_at IS NULL"))
}

model contact_messages {
  id         Int       @id @default(autoincrement())
  name       String
  email      String
  message    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([created_at], map: "idx_contact_created")
}

model email_sends {
  id         Int      @id @default(autoincrement())
  booking_id String?
  template   String
  recipient  String
  subject    String
  status     String   @default("sent")
  error      String?
  sent_at    DateTime @default(now()) @db.Timestamptz(6)

  @@index([booking_id, sent_at(sort: Desc)], map: "email_sends_booking_id_idx")
  @@index([sent_at(sort: Desc)], map: "email_sends_sent_at_idx")
}

model failed_webhook_events {
  id                Int       @id @default(autoincrement())
  event_id          String
  event_type        String
  stripe_session_id String?
  stripe_payment_id String?
  booking_id        String?
  event_data        String?
  error_message     String?
  resolved          Boolean?  @default(false)
  resolved_at       DateTime? @db.Timestamp(6)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  retry_count       Int?      @default(0)
  last_retry_at     DateTime? @db.Timestamp(6)

  @@index([resolved], map: "idx_failed_webhook_unresolved", where: raw("(resolved = false)"))
}

model gallery_images {
  id            Int       @id @default(autoincrement())
  filename      String
  title         String?
  description   String?
  property      String?
  is_hero       Boolean?  @default(false)
  is_featured   Boolean?  @default(false)
  display_order Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
}

model processed_webhook_events {
  event_id     String    @id
  processed_at DateTime? @default(now()) @db.Timestamp(6)
}

model review_requests {
  id                   Int     @id @default(autoincrement())
  booking_id           String  @unique
  guest_email          String
  guest_name           String?
  accommodation        String?
  check_out            String?
  request_count        Int?    @default(0)
  last_request_sent_at String?
  last_error           String?
  status               String? @default("pending")
  created_at           String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  // Cron query: WHERE status = 'pending' AND last_request_sent_at < now()-7d
  @@index([status, last_request_sent_at])
}

model reviews {
  id             Int       @id @default(autoincrement())
  guest_name     String
  platform       String?   @default("direct")
  rating         Int?      @default(5)
  review_text    String?
  stay_date      DateTime? @db.Date
  property       String?
  status         String?   @default("pending")
  is_featured    Boolean?  @default(false)
  admin_notes    String?
  admin_response String?
  response_date  DateTime? @db.Timestamp(6)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  // Hot query paths:
  //  - public /reviews page: where status='approved' order by stay_date desc
  //  - admin reviews list: where status=? [platform=?] [property=?] order by created_at desc
  //  - structured-data fetchReviewStats: where status='approved' and property=?
  // Column names here follow the snake_case schema (property, created_at).
  @@index([status, stay_date(sort: Desc)])
  @@index([status, created_at(sort: Desc)])
  @@index([status, property])
}

model schema_migrations {
  id         Int       @id @default(autoincrement())
  filename   String    @unique
  applied_at DateTime? @default(now()) @db.Timestamp(6)
}

model seasonal_rates {
  id         Int       @id @default(autoincrement())
  name       String
  start_date DateTime  @db.Date
  end_date   DateTime  @db.Date
  multiplier Decimal?  @default(1.00) @db.Decimal(3, 2)
  is_active  Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

model social_content_drafts {
  id                Int     @id @default(autoincrement())
  platform          String
  source_type       String?
  source_text       String?
  accommodation     String?
  generated_caption String?
  hashtags          String?
  story_text        String?
  status            String? @default("draft")
  created_at        String? @default(dbgenerated("CURRENT_TIMESTAMP"))
}

model system_settings {
  id            Int       @id @default(autoincrement())
  setting_key   String    @unique
  setting_value String?
  setting_type  String?   @default("string")
  updated_at    DateTime? @default(now()) @db.Timestamp(6)

  @@index([setting_key], map: "idx_settings_key")
}

model token_blacklist {
  token_hash String   @id
  expires_at DateTime @db.Timestamp(6)
}

model rate_limits {
  key         String   @id
  count       Int      @default(0)
  reset_time  DateTime @db.Timestamp(6)

  @@index([reset_time], map: "idx_rate_limits_reset_time")
}

model login_attempts {
  ip            String   @id
  count         Int      @default(0)
  locked_until  DateTime @default(dbgenerated("to_timestamp(0)")) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @db.Timestamp(6)

  @@index([locked_until], map: "idx_login_attempts_locked_until")
}

model blocked_dates {
  id         Int       @id @default(autoincrement())
  property   String
  start_date DateTime  @db.Date
  end_date   DateTime  @db.Date
  reason     String?   @default("maintenance")
  notes      String?
  created_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([property], map: "idx_blocked_dates_property")
  @@index([start_date, end_date], map: "idx_blocked_dates_range")
}

model promo_codes {
  id             Int       @id @default(autoincrement())
  name           String
  code           String    @unique
  type           String?   @default("general")
  description    String?
  discount_type  String
  discount_value Decimal   @db.Decimal(10, 2)
  valid_from     DateTime? @db.Date
  valid_until    DateTime? @db.Date
  min_stay       Int?
  usage_limit    Int?
  usage_count    Int?      @default(0)
  status         String?   @default("active")
  partner_info   String?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  @@index([code], map: "idx_promo_codes_code")
  @@index([status], map: "idx_promo_codes_status")
}
